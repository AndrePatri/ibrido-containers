Bootstrap: docker
From:nvcr.io/nvidia/isaac-sim:5.1.0

%labels
    AUTHOR AndrePatri (andrepatrics@gmail.com)
    Version v1.0.0

%help
    This is the Singularity container associated with the IBRIDO framework.

#%arguments
#    wandb_key=""

%files # copy isaac kits
    ./files/omni.isaac.sim.python.aug_mpc_envs.isaac5.1.headless.kit /isaac-sim/apps/
    ./files/omni.isaac.sim.python.aug_mpc_envs.isaac5.1.kit /isaac-sim/apps

%environment
    
    export DEBIAN_FRONTEND=noninteractive
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export ROS_DISTRO=jazzy
    export ACCEPT_EULA=Y
    export force_color_prompt=Y
    export WANDB_KEY=""
    export LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu:/.singularity.d/libs
#    export SINGULARITY_MEMORY=
#    export SINGULARITY_MEMORY_SWAP=

#%setup

%post
    # writing some composite singularity env. variables
    HOME='/root'
    MAMBA_ENV_NAME='ibrido'
    MAMBA_ENV_NAME_ISAAC='ibrido_isaac_py11'
    MAMBA_EXE_PREFIX='/usr/local/bin'
    MAMBA_EXE='${MAMBA_EXE_PREFIX}/micromamba'
    MAMBA_ROOT_PREFIX='/opt/conda'
    MAMBA_ENV_FPATH='${HOME}/ibrido_files/mamba_env.yml'
    MAMBA_ENV_FPATH_ISAAC='${HOME}/ibrido_files/mamba_env_isaac_py11.yml'

    PATH=$PATH:${HOME}/.local/bin:${HOME}/ibrido_utils:${HOME}/ibrido_files

    echo "export HOME=\"${HOME}\"" >> $SINGULARITY_ENVIRONMENT
    echo "export MAMBA_ENV_NAME=\"${MAMBA_ENV_NAME}\"" >> $SINGULARITY_ENVIRONMENT
    echo "export MAMBA_ENV_NAME_ISAAC=\"${MAMBA_ENV_NAME_ISAAC}\"" >> $SINGULARITY_ENVIRONMENT
    echo "export MAMBA_ENV_FPATH=\"${MAMBA_ENV_FPATH}\"" >> $SINGULARITY_ENVIRONMENT
    echo "export MAMBA_ENV_FPATH_ISAAC=\"${MAMBA_ENV_FPATH_ISAAC}\"" >> $SINGULARITY_ENVIRONMENT
    echo "export PATH=\"${PATH}\"" >> $SINGULARITY_ENVIRONMENT
    echo "export MAMBA_EXE_PREFIX=\"${MAMBA_EXE_PREFIX}\"" >> $SINGULARITY_ENVIRONMENT
    echo "export MAMBA_EXE=\"${MAMBA_EXE}\"" >> $SINGULARITY_ENVIRONMENT
    echo "export MAMBA_ROOT_PREFIX=\"${MAMBA_ROOT_PREFIX}\"" >> $SINGULARITY_ENVIRONMENT
    
    apt-get update && apt-get install -y --no-install-recommends byobu nano cmake clang cmake-curses-gui curl swig ffmpeg zstd tzdata unzip \
        python3 python3-venv python-is-python3 \
        git wget sudo vim iputils-ping ssh rsync \
        plocate \
        libboost-all-dev \
        libyaml-cpp-dev \
        libpugixml-dev \
        libzmq3-dev \
        cppzmq-dev \
        libglfw3-dev \
        python3-pybind11 \
        mesa-utils \
        build-essential \
        htop \
        nvtop \
        dbus \
        libasound2t64 \
        libatk-bridge2.0-0t64 \
        libgbm1 \
        libnss3 \
        libpulse0 \
        libxcomposite1 \
        libxdamage1 \
        libxkbcommon-x11-0 \
        libxrandr2 \
        libxcb-cursor0 \
        libxcb-icccm4 \
        libxcb-image0 \
        libxcb-keysyms1 \
        libxcb-randr0 \
        libxcb-render-util0 \
        libxcb-shape0 \
        libxcb-util1 \
        libxcb-xfixes0 \
        libxcb-xkb1 \
        && rm -rf /var/lib/apt/lists/*

    # Generate the machine-id
    dbus-uuidgen --ensure=/var/lib/dbus/machine-id
    # Create the /etc/machine-id symlink (common practice)
    ln -sf /var/lib/dbus/machine-id /etc/machine-id

    # Micromamba setup
    # ensure decompression tools + file are present
    apt-get update && apt-get install -y --no-install-recommends bzip2 xz-utils gzip file curl && rm -rf /var/lib/apt/lists/*

    # Micromamba setup - robust + properly quoted vars
    MAMB_URL="https://micro.mamba.pm/api/micromamba/linux-64/latest"
    TMPF="/tmp/micromamba.tar"
    MAMBA_EXE_PREFIX="/usr/local/bin"
    MAMBA_EXE="${MAMBA_EXE_PREFIX}/micromamba"
    mkdir -p "${MAMBA_EXE_PREFIX}"

    echo "Downloading micromamba from ${MAMB_URL} to ${TMPF}..."
    curl --fail -sSL "${MAMB_URL}" -o "${TMPF}" || { echo "micromamba download failed"; rm -f "${TMPF}"; exit 1; }

    # check mime-type and attempt extraction with fallbacks
    mime="$(file -b --mime-type "${TMPF}" || true)"
    echo "micromamba file mime-type: ${mime}"

    # Try the common compressions; fall back to tar auto-detect
    case "${mime}" in
        application/x-bzip2|application/x-bz2)
            tar -xjf "${TMPF}" -C "${MAMBA_EXE_PREFIX}" --strip-components=1 "bin/micromamba" || true
            ;;
        application/x-xz)
            tar -xJf "${TMPF}" -C "${MAMBA_EXE_PREFIX}" --strip-components=1 "bin/micromamba" || true
            ;;
        application/gzip)
            tar -xzf "${TMPF}" -C "${MAMBA_EXE_PREFIX}" --strip-components=1 "bin/micromamba" || true
            ;;
        application/x-tar|application/octet-stream)
            tar -xvf "${TMPF}" -C "${MAMBA_EXE_PREFIX}" --strip-components=1 "bin/micromamba" || true
            ;;
        *)
            echo "Unknown archive type (${mime}) — attempting extraction with tar auto-detect"
            tar -xvf "${TMPF}" -C "${MAMBA_EXE_PREFIX}" --strip-components=1 "bin/micromamba" || true
            ;;
    esac

    # If micromamba isn't present or not executable, print diagnostic and fail
    if [ ! -x "${MAMBA_EXE}" ]; then
        echo "micromamba missing or not executable at ${MAMBA_EXE}"
        echo "Listing ${MAMBA_EXE_PREFIX}:"
        ls -l "${MAMBA_EXE_PREFIX}" || true
        # Show tar contents as additional debug (this is harmless inside build)
        echo "Tar listing (first 50 lines):"
        tar -tf "${TMPF}" | sed -n '1,50p' || true
        rm -f "${TMPF}"
        exit 1
    fi

    chmod 755 "${MAMBA_EXE}"
    rm -f "${TMPF}"
    
    # ROS 2 base setup
    echo 'Etc/UTC' > /etc/timezone
    apt-get update && DEBIAN_FRONTEND=noninteractive TZ=Etc/UTC apt-get install -q -y --no-install-recommends tzdata && rm -rf /var/lib/apt/lists/*

    apt-get update && apt-get install -q -y --no-install-recommends \
        dirmngr \
        gnupg2 && rm -rf /var/lib/apt/lists/*

    curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key -o /usr/share/keyrings/ros-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] http://packages.ros.org/ros2/ubuntu $(. /etc/os-release && echo $UBUNTU_CODENAME) main" | tee /etc/apt/sources.list.d/ros2.list > /dev/null

    apt-get update && apt-get install --no-install-recommends -y \
        git \
        python3-rosdep \
        python3-vcstool && rm -rf /var/lib/apt/lists/*

    ROS_DISTRO='jazzy'
    rosdep init && \
      rosdep update --rosdistro $ROS_DISTRO

    apt-get update && apt-get install -y --no-install-recommends \
        ros-jazzy-ros-base \
        ros-jazzy-rviz2 && rm -rf /var/lib/apt/lists/*

    # XBot2 setup, required by xbot2_zmq. Use the nightly repository because
    # the stable XBot2 apt repository does not publish Ubuntu 24.04 packages.
    wget -qO- http://xbot.cloud/xbot2-nightly/ubuntu/KEY.gpg | gpg --batch --yes --dearmor -o /usr/share/keyrings/xbot2-archive-keyring.gpg
    XBOT2_UBUNTU_CODENAME="$(. /etc/os-release && echo $UBUNTU_CODENAME)"
    echo "deb [signed-by=/usr/share/keyrings/xbot2-archive-keyring.gpg] http://xbot.cloud/xbot2-nightly/ubuntu/${XBOT2_UBUNTU_CODENAME} /" > /etc/apt/sources.list.d/xbot2.list
    apt-get update
    if ! apt-cache policy xbot2_desktop_full | grep -q 'Candidate: [^(]'; then
        echo "XBot2 apt packages are not available for Ubuntu ${XBOT2_UBUNTU_CODENAME} from http://xbot.cloud/xbot2-nightly/ubuntu/${XBOT2_UBUNTU_CODENAME}."
        exit 1
    fi
    apt-get install -y --no-install-recommends xbot2_desktop_full && rm -rf /var/lib/apt/lists/*

    # Robot Monitoring GUI setup. Follow the xbot2 Docker workflow: install the
    # Python launcher/server package, then preinstall the Qt client where the
    # launcher expects it so startup does not need network access.
    XBOT2_GUI_VENV='/opt/xbot2gui-venv'
    XBOT2_GUI_SITE=''
    XBOT2_GUI_CLIENT_HOME='/root/.xbot2_gui_client'
    XBOT2_GUI_SERVER_REF='proto_ros2'
    ROBOT_MONITORING_VERSION='v2.7.5'
    ROBOT_MONITORING_SHA256='d689db57308bf866289b6639db7347d02f076319b350ff21eaa89fb3f4b67aeb'
    ROBOT_MONITORING_ARCHIVE='/tmp/xbot2_gui_client_x86_64.zip'
    ROBOT_MONITORING_URL="https://github.com/ADVRHumanoids/robot_monitoring/releases/download/${ROBOT_MONITORING_VERSION}/xbot2_gui_client_x86_64.zip"

    python3 -m venv --system-site-packages "${XBOT2_GUI_VENV}"
    "${XBOT2_GUI_VENV}/bin/python" -m pip install --no-cache-dir --upgrade pip
    "${XBOT2_GUI_VENV}/bin/python" -m pip install --no-cache-dir concert_launcher==0.1.1
    "${XBOT2_GUI_VENV}/bin/python" -m pip install --no-cache-dir \
        "git+https://github.com/ADVRHumanoids/robot_monitoring.git@${XBOT2_GUI_SERVER_REF}#egg=xbot2-gui-server&subdirectory=server"
    XBOT2_GUI_SITE="$("${XBOT2_GUI_VENV}/bin/python" -c 'import site; print(site.getsitepackages()[0])')"
    mkdir -p "${XBOT2_GUI_SITE}/xbot2_gui_server/webui"

    rm -rf "${XBOT2_GUI_CLIENT_HOME}"
    mkdir -p "${XBOT2_GUI_CLIENT_HOME}"
    curl --fail -L "${ROBOT_MONITORING_URL}" -o "${ROBOT_MONITORING_ARCHIVE}"
    echo "${ROBOT_MONITORING_SHA256}  ${ROBOT_MONITORING_ARCHIVE}" | sha256sum -c -
    unzip -q "${ROBOT_MONITORING_ARCHIVE}" -d "${XBOT2_GUI_CLIENT_HOME}"
    rm -f "${ROBOT_MONITORING_ARCHIVE}"
    chmod -R a+rX "${XBOT2_GUI_VENV}" "${XBOT2_GUI_CLIENT_HOME}"
    cat > /usr/local/bin/xbot2-gui <<'EOF'
#!/usr/bin/env bash
set -e

if [ -f /opt/ros/jazzy/setup.bash ]; then
    source /opt/ros/jazzy/setup.bash
fi
if [ -f /opt/xbot/setup.sh ]; then
    source /opt/xbot/setup.sh
fi

export PATH="/opt/xbot2gui-venv/bin:${PATH}"
if [ -d /root/.xbot2_gui_client ]; then
    export HOME="${IBRIDO_CONTAINER_HOME:-/root}"
fi
XBOT2_GUI_CLIENT_DIR="${HOME:-/root}/.xbot2_gui_client/xbot2_gui_client_x86_64"
export LD_LIBRARY_PATH="${XBOT2_GUI_CLIENT_DIR}/lib:${LD_LIBRARY_PATH:-}"
export QTWEBENGINE_DISABLE_SANDBOX="${QTWEBENGINE_DISABLE_SANDBOX:-1}"
unset QT_PLUGIN_PATH
unset QML2_IMPORT_PATH

exec /opt/xbot2gui-venv/bin/xbot2_gui "$@"
EOF
    chmod 755 /usr/local/bin/xbot2-gui
    ln -sf /usr/local/bin/xbot2-gui /usr/local/bin/xbot2_gui
    ln -sf "${XBOT2_GUI_VENV}/bin/concert_launcher" /usr/local/bin/concert_launcher
    
    # give access to /isaac-sim folder to anybody (root only by default)
    chmod --recursive 777 /isaac-sim

%test
    echo 'Testing if MicroMamba is present...'
    ${MAMBA_EXE} --version
    test -x /usr/local/bin/xbot2-gui
    test -x /usr/local/bin/xbot2_gui
    test -x /opt/xbot2gui-venv/bin/xbot2_gui
    test -x /opt/xbot2gui-venv/bin/xbot2_gui_server
    test -x /opt/xbot2gui-venv/bin/concert_launcher
    test -x /usr/local/bin/concert_launcher
    test -x /root/.xbot2_gui_client/xbot2_gui_client_x86_64/bin/xbot2_gui
    # echo 'Testing byobu is installed...'
    # which byobu || { echo "byobu missing"; exit 1; }

%runscript
    exec /bin/bash "$@"

%startscript
    exec /bin/bash "$@"
